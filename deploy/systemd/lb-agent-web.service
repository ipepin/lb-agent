[Unit]
Description=LB-AGENT web
After=network.target

[Service]
Type=simple
User=blaze
WorkingDirectory=/opt/lb-agent
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/opt/lb-agent/.env
ExecStart=/opt/lb-agent/.venv/bin/uvicorn app.web.api:create_app --factory --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
