[Unit]
Description=LB-AGENT worker
After=network.target

[Service]
Type=simple
User=blaze
WorkingDirectory=/opt/lb-agent
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/opt/lb-agent/.env
ExecStart=/opt/lb-agent/.venv/bin/python run_worker.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
